# === Database ===
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# === Redis ===
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# === Backend ===
# APP_ENV: development / production（production 會啟用 cookie secure flag）
APP_ENV=development
BACKEND_PORT=8000
SECRET_KEY=
CORS_ORIGINS=["http://localhost:3000"]
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
SKILLS_UPLOAD_DIR=data/skills
SKILLS_MAX_FILE_SIZE=52428800
ATTACHMENTS_UPLOAD_DIR=data/attachments

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# === OpenRouter（LLM 對話 + embedding 統一入口）===
OPENROUTER_API_KEY=
# 開發環境填 http://localhost:3000；上線環境填部署網址，禁直接 commit production 值
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Agents Memory System

# v1.3.0：LLM 成本 metrics counterfactual baseline 用的 expensive 模型 id
# 用於 llm_metering wrapper 計算 baseline_cost_usd（沒 classifier 時會花多少）
LLM_BASELINE_EXPENSIVE_MODEL=anthropic/claude-sonnet-4-6

# === LINE ===
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# === Telegram ===
TELEGRAM_BOT_TOKEN=

# === DF-SSO（中央 OAuth2 / Azure AD）===
# Prod: https://df-sso-login.apps.zerozero.tw
# Test: https://df-sso-login-test.apps.zerozero.tw
# Dev:  http://localhost:3001
SSO_URL=https://df-sso-login.apps.zerozero.tw
# 從目標環境的 SSO Dashboard 取得（每環境各一組）
SSO_APP_ID=
SSO_APP_SECRET=
# APP_URL = 本系統 frontend origin，必須在 SSO Dashboard 的 redirect_uris 白名單
APP_URL=http://localhost:3000

# Frontend 走 Next.js Route Handler 處理 back-channel logout 時，需後端內網位址轉發；
# 容器內走 service name，外部部署可用 backend public URL。可不設，會 fallback 到 NEXT_PUBLIC_API_URL
BACKEND_INTERNAL_URL=http://backend:8000/api/v1

# 跨子網域共享 cookie domain（如 .zerozero.tw）。設定後 sso_recent_logout / last_login_provider
# 等 hint cookie 會跨 *.zerozero.tw 上所有 SSO 接入 App 共享, 達成「一處登入 / 登出, 他處同步」。
# 本機開發留空 = host-only cookie, 不跨域。
SSO_COOKIE_DOMAIN=

# === Flyway ===
FLYWAY_URL=jdbc:postgresql://postgres:5432/agents_memory
FLYWAY_USER=
FLYWAY_PASSWORD=
