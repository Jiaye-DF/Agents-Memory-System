# === Database ===
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# === Redis ===
# 連線字串為主, HOST/PORT/DB 提供給需要拆解部位的工具
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# === Backend ===
# development / test / production（production 會啟用 cookie secure flag）
APP_ENV=development
BACKEND_PORT=8000
# JWT 簽章金鑰, 至少 32 字元, 建議 64 字元亂數
SECRET_KEY=
# JSON 陣列字串, production 下禁用 "*" 與 localhost
CORS_ORIGINS=["http://localhost:3000"]
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# 本地檔案儲存路徑（後續會切換到 S3）
SKILLS_UPLOAD_DIR=data/skills
# 單檔上限, 單位 bytes（50 MB）
SKILLS_MAX_FILE_SIZE=52428800
ATTACHMENTS_UPLOAD_DIR=data/attachments

# === AWS S3 ===
# IAM User 程式憑證, 由 AWS Console IAM User → 安全憑證 取得（secret 只顯示一次）
# test / prod 環境必須各自獨立一組 IAM User + bucket, 嚴禁共用
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-1
# bucket 命名: agents-platform-test-datas / agents-platform-prod-datas
S3_BUCKET=

# === Frontend ===
# Next.js 於 build 階段內聯 NEXT_PUBLIC_*, 改值後須重新 build 才生效
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# === OpenRouter ===
# LLM + embedding 統一入口 API key
OPENROUTER_API_KEY=
# OpenRouter 後台辨識用, 填本系統 frontend origin
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Agents Memory System
# LLM 成本 metrics counterfactual baseline 用的 expensive 模型 id
LLM_BASELINE_EXPENSIVE_MODEL=anthropic/claude-sonnet-4-6

# === DF-SSO ===
# 中央 SSO 服務 base URL（測試 / 正式各一組）
SSO_URL=https://df-sso-login.apps.zerozero.tw
# 本系統在 SSO 註冊的 client_id / client_secret
SSO_APP_ID=
SSO_APP_SECRET=
# 本系統 frontend 公開 URL, 須在 SSO Dashboard redirect_uris 白名單
APP_URL=http://localhost:3000
# frontend route handler 轉發 webhook 給 backend 走內網, 不設則 fallback 到 NEXT_PUBLIC_API_URL
BACKEND_INTERNAL_URL=http://backend:8000/api/v1
# 跨子網域共享 hint cookie domain（如 .zerozero.tw）, 留空 = host-only cookie 不跨域
SSO_COOKIE_DOMAIN=

# === Flyway ===
FLYWAY_URL=jdbc:postgresql://postgres:5432/agents_memory
FLYWAY_USER=
FLYWAY_PASSWORD=
