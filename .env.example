# === Database ===
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Backend ===
# APP_ENV: development / production（production 會啟用 cookie secure flag）
APP_ENV=development
BACKEND_PORT=8000
SECRET_KEY=
CORS_ORIGINS=["http://localhost:3000"]
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
SKILLS_UPLOAD_DIR=data/skills
SKILLS_MAX_FILE_SIZE=52428800

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# === OpenRouter（LLM 對話 + embedding 統一入口）===
OPENROUTER_API_KEY=
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_APP_TITLE=Agents Memory System

# === LINE ===
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# === Telegram ===
TELEGRAM_BOT_TOKEN=

# === Flyway ===
FLYWAY_URL=jdbc:postgresql://postgres:5432/agents_memory
FLYWAY_USER=
FLYWAY_PASSWORD=
